{
  "name": "uk-financial-products-comparison-platform",
  "version": "1.0.0",
  "description": "Serverless UK financial products comparison platform with AI insights",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.920.0",
    "@aws-sdk/lib-dynamodb": "^3.920.0"
  },
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
